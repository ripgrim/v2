{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"builder": "DOCKERFILE",
		"dockerfilePath": "apps/api/Dockerfile",
		"watchPatterns": [
			"apps/api/**",
			"packages/**",
			"package.json",
			"bun.lock",
			"bunfig.toml"
		]
	},
	"deploy": {
		"healthcheckPath": "/healthz",
		"healthcheckTimeout": 120,
		"restartPolicyType": "ON_FAILURE",
		"restartPolicyMaxRetries": 10
	}
}
