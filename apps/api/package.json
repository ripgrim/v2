{
	"name": "@tripwire/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"types": "./src/index.ts",
	"scripts": {
		"dev": "bun --env-file=../../.env --watch src/index.ts",
		"tunnel": "cloudflared tunnel --url http://localhost:${API_PORT:-8787}",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@tripwire/auth": "workspace:*",
		"@tripwire/contracts": "workspace:*",
		"@tripwire/db": "workspace:*",
		"@tripwire/forge-github": "workspace:*",
		"@tripwire/utils": "workspace:*",
		"hono": "^4.12.29",
		"pg": "^8.22.0",
		"pg-boss": "^12.26.0",
		"pino": "^10.3.1"
	},
	"devDependencies": {
		"@types/pg": "^8.20.0"
	}
}
