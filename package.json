{
	"name": "tripwire",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"dev": "bun --filter '@tripwire/web' dev",
		"build": "bun --filter '*' build",
		"typecheck": "bun --filter '*' typecheck",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:boundaries": "bun run scripts/check-boundaries.ts",
		"test": "bun test",
		"db:up": "docker compose up -d postgres"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/bun": "^1.2.0",
		"typescript": "^5.7.2",
		"ultracite": "7.8.3"
	},
	"engines": {
		"bun": ">=1.3.0"
	}
}
