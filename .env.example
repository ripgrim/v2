# Copy me: `cp .env.example .env` at the REPO ROOT, then symlink for the web
# dev server (nitro loads dotenv from the app dir, not the repo root):
#   ln -sf ../../.env apps/web/.env
# api/worker read the root .env automatically when run from the root.

# ── Database ──────────────────────────────────────────────────────────────
# Local Postgres (docker compose up -d postgres). In prod this is PlanetScale's
# POOLED URL — transactional ingest, rule reads, web queries.
DATABASE_URL=postgres://tripwire:tripwire@localhost:5432/tripwire
# The DIRECT / session (non-pooled) URL, used ONLY by the SSE LISTEN and the
# worker's NOTIFY (a transaction-pooled connection can't hold a LISTEN). Unset
# locally ⇒ falls back to DATABASE_URL (one local Postgres, no pooler). In prod
# set it to PlanetScale's direct endpoint. `bun run verify:planetscale` gates it.
# DATABASE_URL_DIRECT=

# ── GitHub App (ingest + actions) — VERIFICATION-QUEUE.md #1 ─────────────
GITHUB_APP_ID=
# PEM, quoted, keep newlines: GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
GITHUB_APP_PRIVATE_KEY=
# openssl rand -hex 32 — same value goes in the App's webhook settings
GITHUB_WEBHOOK_SECRET=
# The App's public slug (github.com/apps/<slug>) — builds the install URL on
# /onboarding. Set the App's **Setup URL** to ${APP_URL}/onboarding/setup so
# GitHub returns the user here with ?installation_id=… after they install.
GITHUB_APP_SLUG=

# ── Better Auth (dashboard sign-in) — VERIFICATION-QUEUE.md #6 ───────────
# openssl rand -hex 32. UNSET in dev = gate stands open; production REFUSES
# to boot without it (fail-closed, hardening unit 2).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── Review agent — VERIFICATION-QUEUE.md #7 ──────────────────────────────
# OpenRouter (https://openrouter.ai/keys). Unset = ai-review skips (and
# counts toward the degradation floor).
OPENROUTER_API_KEY=
# Default model (OpenRouter slug). Explicit rule config wins over this.
AI_REVIEW_MODEL=anthropic/claude-fable-5

# ── Economics observability (economics-surface-contracts.md) ─────────────
# Key split: the worker uses the PROD key; evals use the EVAL key; the pull
# cron uses a read-only MANAGEMENT key. Unset = that piece is disabled.
# OPENROUTER_API_KEY_PROD=          # falls back to OPENROUTER_API_KEY
# OPENROUTER_API_KEY_EVAL=          # eval harness spend, kept out of COGS
# OPENROUTER_MANAGEMENT_KEY=        # analytics pull (POST /api/v1/analytics/query)
# OPENROUTER_PROD_KEY_HASH=         # optional: split pulled spend prod vs eval
# OPENROUTER_EVAL_KEY_HASH=
# Railway has no stable billing query, so the usage figure is operator-provided:
# read the current month-to-date usage from the Railway dashboard and set it here.
# RAILWAY_USAGE_USD=1.42
# PlanetScale invoice pull (service token with read_invoices).
# PLANETSCALE_SERVICE_TOKEN_ID=
# PLANETSCALE_SERVICE_TOKEN=
# PLANETSCALE_ORG=
# Discord destination for the economics digest + alerts (falls back to
# FEEDBACK_WEBHOOK_URL).
# ECONOMICS_WEBHOOK_URL=
# Alert thresholds (defaults shown; override to tune).
# OR_DAILY_CAP_USD=1.00
# DRIFT_ALERT_PCT=10
# RAILWAY_FLOOR_WARN_USD=4.50

# ── Re-run cooldown ──────────────────────────────────────────────────────
# Seconds one change request stays locked after a manual re-run enqueue
# (pg-boss singleton). Default 300 (5 min). Set 0 to disable globally.
# Per-account exemption is a staff flag on /admin/users (rerunCooldownExempt).
# RERUN_COOLDOWN_SECONDS=300

# ── Service wiring (defaults shown; only change if you move ports) ───────
# Base URL for run deep links in comments/checks (the web dashboard).
APP_URL=http://localhost:3000
# CORS origin the api allows for SSE + auth (the web dashboard).
WEB_ORIGIN=http://localhost:3000
# api listen port.
API_PORT=8787
# Where the web head's start.ts middleware finds the api (server-side SSE proxy).
VITE_API_URL=http://localhost:8787
# Absolute-URL base for SEO tags.
VITE_SITE_URL=http://localhost:3000

# ── Databuddy (analytics + closed-beta access gate) ──────────────────────
# The public client id is hardcoded (packages/auth/src/databuddy.ts) — the
# <Databuddy> analytics component AND the server `access-gate` flag evaluate
# against it. Optional server API key is only for future server-side event
# tracking (unused today).
# DATABUDDY_API_KEY=
# Closed-beta gate kill-switch. Databuddy's `access-gate` flag is the primary
# control; this is the fallback when the flag is unresolved / Databuddy is down.
# ACCESS_GATE_ENABLED=true
# Landing origins allowed to receive the waitlist popup's postMessage
# (comma-separated). /oauth/popup-callback only posts to an exact origin from
# this list. Point at the tripwire-landing origin(s).
# PROD: the landing 308s apex→www, so visitors are on www — include BOTH forms
# (www is what actually matches; do NOT tidy to the apex alone):
#   VITE_WAITLIST_OPENER_ORIGINS=https://tripwire.sh,https://www.tripwire.sh
VITE_WAITLIST_OPENER_ORIGINS=http://localhost:3001
# ── In-app feedback (web) ────────────────────────────────────────────────
# Where the "Send feedback" dialog forwards to (Discord webhook URL). Unset ⇒
# the form still works but drops the submission (a no-op, logged) — fine in dev.
# FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/…

# ── Test-run trigger (bun run test:run) — push an empty commit to a scratch PR
# to fire a fresh Tripwire run end-to-end. Point it at your own sacrificial repo.
# The live E2E harness (`bun run test`, scripts/e2e/) reuses this same surface.
TEST_REPO=Boring-Software-Inc/scratch
TEST_BRANCH=fix-typo
# TEST_WORKDIR defaults to $TMPDIR/tripwire-e2e
# The harness preflights the webhook API's /healthz before opening a real PR;
# point this at the URL GitHub posts webhooks to (defaults to VITE_API_URL, then
# http://localhost:8787). A down API fails fast instead of a silent no-run.
# TEST_API_URL=http://localhost:8787

# ── Harness degraded scenario (`bun run test --only gate-degraded`) ──────
# Set on the WORKER (dev only; refused under NODE_ENV=production) so the §11
# harness can exercise the fail-closed floor on a live PR: the named context
# reads throw → rules skip → verdict floors to needs_review.
#   TRIPWIRE_FAIL_READS=all           # or a list: diff,commits,contributor

# ── Prod lifecycle E2E (`bun run test:lifecycle:prod`) ───────────────────
# That command loads a SEPARATE gitignored file, `.env.e2e` (NOT this one),
# via `bun --env-file`. Create it with the three vars below to drive the live
# comment lifecycle on prod as a non-exempt fork PR (no tokens — the script
# `gh auth switch`es between the two accounts, which must both be `gh auth
# login`'d). The contributor account must have READ-ONLY (not write) access to
# TEST_REPO, or it's exempt.
#   DATABASE_URL=<PlanetScale POOLED url>   # the DB the prod worker reads
#   TEST_CONTRIBUTOR=<non-exempt alt gh username>
#   TEST_MAINTAINER=<maintainer gh username, restored/merged as>
